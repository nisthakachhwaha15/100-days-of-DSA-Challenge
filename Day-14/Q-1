#include <stdio.h>

int main() {
    int n;

    printf("Enter size of matrix: ");
    scanf("%d", &n);

    int A[100][100];

    // Input matrix
    printf("Enter matrix elements:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &A[i][j]);
        }
    }

    int isIdentity = 1;

    // Check identity matrix
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (i == j) {
                if (A[i][j] != 1) {
                    isIdentity = 0;
                    break;
                }
            } else {
                if (A[i][j] != 0) {
                    isIdentity = 0;
                    break;
                }
            }
        }
        if (!isIdentity)
            break;
    }

    if (isIdentity)
        printf("Identity Matrix\n");
    else
        printf("Not an Identity Matrix\n");

    return 0;
}
