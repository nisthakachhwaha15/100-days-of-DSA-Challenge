#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

// Node structure for stack
struct Node {
    int data;
    struct Node* next;
};

// Push operation
void push(struct Node** top, int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    newNode->next = *top;
    *top = newNode;
}

// Pop operation
int pop(struct Node** top) {
    if (*top == NULL) {
        printf("Stack Underflow\n");
        return -1;
    }

    struct Node* temp = *top;
    int value = temp->data;
    *top = temp->next;
    free(temp);
    return value;
}

int main() {
    char exp[100];
    struct Node* stack = NULL;

    printf("Enter postfix expression: ");
    
    // Read full line (with spaces)
    fgets(exp, sizeof(exp), stdin);

    int i = 0;

    while (exp[i] != '\0') {

        // Skip spaces
        if (exp[i] == ' ') {
            i++;
            continue;
        }

        // If digit → push
        if (isdigit(exp[i])) {
            int num = exp[i] - '0';
            push(&stack, num);
        }
        // Operator
        else {
            int b = pop(&stack);
            int a = pop(&stack);
            int result;

            switch (exp[i]) {
                case '+': result = a + b; break;
                case '-': result = a - b; break;
                case '*': result = a * b; break;
                case '/': result = a / b; break;
            }

            push(&stack, result);
        }

        i++;
    }

    // Final result
    printf("%d\n", pop(&stack));

    return 0;
}
