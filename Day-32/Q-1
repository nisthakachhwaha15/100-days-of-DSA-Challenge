#include <stdio.h>

#define MAX 100

int stack[MAX];
int top = -1;

// Push function
void push(int x) {
    if (top == MAX - 1)
        return; // ignore overflow for simplicity
    stack[++top] = x;
}

// Pop function
void pop() {
    if (top == -1)
        return; // ignore underflow
    top--;
}

// Display stack
void display() {
    for (int i = top; i >= 0; i--) {
        printf("%d ", stack[i]);
    }
}

int main() {
    int n, m;

    scanf("%d", &n);

    // Push elements
    for (int i = 0; i < n; i++) {
        int x;
        scanf("%d", &x);
        push(x);
    }

    // Number of pops
    scanf("%d", &m);

    // Perform pops
    for (int i = 0; i < m; i++) {
        pop();
    }

    // Display remaining stack
    display();

    return 0;
}
