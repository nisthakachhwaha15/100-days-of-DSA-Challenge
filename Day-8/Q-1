#include <stdio.h>

// Recursive function
int power(int a, int b) {
    if (b == 0)
        return 1;   // base case

    return a * power(a, b - 1);
}

int main() {
    int a, b;

    printf("Enter base and exponent: ");
    scanf("%d %d", &a, &b);

    printf("Result: %d\n", power(a, b));

    return 0;
}
