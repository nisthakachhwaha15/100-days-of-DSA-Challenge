#include <stdio.h>
#include <stdlib.h>

// BST Node Structure
typedef struct Node {
    int data;
    struct Node* left;
    struct Node* right;
} Node;

// Create a new BST node
Node* createNode(int data) {
    Node* newNode = (Node*)malloc(sizeof(Node));
    newNode->data = data;
    newNode->left = NULL;
    newNode->right = NULL;
    return newNode;
}

// Recursive Insert function in BST
Node* insert(Node* root, int data) {
    if (root == NULL) {
        return createNode(data);        // Base case
    }
    
    if (data < root->data) {
        root->left = insert(root->left, data);
    }
    else if (data > root->data) {
        root->right = insert(root->right, data);
    }
    // Ignore duplicates (standard BST behavior)
    
    return root;
}

// Inorder Traversal (prints elements in sorted order)
void inorder(Node* root) {
    if (root == NULL) return;
    
    inorder(root->left);
    printf("%d ", root->data);
    inorder(root->right);
}

// Free tree memory
void freeTree(Node* root) {
    if (root == NULL) return;
    freeTree(root->left);
    freeTree(root->right);
    free(root);
}

int main() {
    int N;
    scanf("%d", &N);
    
    Node* root = NULL;
    
    // Read N values and insert into BST one by one
    for (int i = 0; i < N; i++) {
        int x;
        scanf("%d", &x);
        root = insert(root, x);
    }
    
    // Print BST in sorted order using Inorder traversal
    inorder(root);
    printf("\n");
    
    // Clean up
    freeTree(root);
    
    return 0;
}
